# ─── Django ───
DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql://ai_amooz:ai_amooz_password@localhost:5432/ai_amooz

# ─── Redis / Celery ───
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CHAT_REDIS_URL=redis://localhost:6379/0

# ─── AI / LLM APIs ───
AVALAI_API_KEY=
AVALAI_BASE_URL=https://api.avalai.ir
GEMINI_API_KEY=
MODEL_NAME=models/gemini-2.5-flash
TRANSCRIPTION_MODEL=models/gemini-2.5-flash
REWRITE_MODEL=models/gemini-2.5-flash
IMAGE_MODEL=models/gemini-3-pro-image-preview
EMBEDDING_MODEL_NAME=models/gemini-embedding-001
MODE=avalai
GENAI_HTTP_TIMEOUT=1000

# ─── Transcription ───
TRANSCRIBE_CHUNK_SECONDS=20
FRAME_MAX_FRAMES_FOR_MODEL=40
FRAME_HARD_CAP=16
MAX_TOTAL_FRAME_BYTES_MB=3
FRAME_EXTRACTION_FPS=0.25

# ─── SMS (Mediana) ───
MEDIANA_API_KEY=

# ─── Pipeline ───
CLASS_PIPELINE_ASYNC=True

# ─── PDF ingestion (Step 1 alternative to media) — LLM-only extraction ───
PDF_MAX_UPLOAD_MB=100
PDF_MAX_PAGES=200
# Page render resolution sent to the vision model (lower = fewer image tokens).
PDF_RENDER_DPI=150
PDF_EXTRACTION_CONCURRENCY=4
PDF_MAX_IMAGE_BYTES_MB=3
# Skip blank pages (no text/figures, near-uniform render) — saves an LLM call.
PDF_SKIP_BLANK_PAGES=True
PDF_BLANK_STD_THRESHOLD=3.0
# Embedded-figure filters: ignore images smaller than these (decorative icons).
PDF_IMAGE_MIN_PX=64
PDF_IMAGE_MIN_BYTES=1024
# Override the vision model (else falls back to MODEL_NAME). Must be multimodal.
# PDF_VISION_MODEL=gemini-2.5-flash
# Deprecated (LLM-only no longer routes on the text layer); kept for back-compat.
PDF_TEXT_LAYER_MIN_CHARS=80
PDF_FORCE_VISION=False

# ─── CORS / CSRF ───
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:9002
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── S3 / MinIO (Object Storage) ───
# Set AWS_STORAGE_BUCKET_NAME to enable S3 storage; leave blank for local filesystem.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ai-amooz-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_QUERYSTRING_AUTH=False

# ─── Gunicorn ───
PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300
GUNICORN_WORKER_CLASS=sync

# ─── Throttle ───
THROTTLE_RATE_ANON=60/minute
THROTTLE_RATE_USER=300/minute

# ─── Upload Limits ───
MAX_UPLOAD_MB=500
TRANSCRIPTION_MAX_UPLOAD_MB=500
